# copy to .env and fill in. keep this file LF / UTF-8, no BOM.
# do NOT put comments on the same line as a value.

# your Gonka broker key (Bearer for proxy.gonka.gg)
GONKA_API_KEY=

# auth key for the Hermes API server. leave blank — install.sh generates one.
HERMES_API_KEY=

# domain for the public dashboard. leave the example value to skip Caddy
# (the panel is then reachable only over an SSH tunnel to 127.0.0.1:9119).
DOMAIN=hermes.example.com

# Telegram bot (optional). Get a token from @BotFather. This is the ONLY place
# you set it — the dashboard has no field for it. After setting it, run:
#   docker compose up -d hermes
TELEGRAM_BOT_TOKEN=
# comma-separated Telegram user ids allowed to use the bot, e.g. 12345,67890
TELEGRAM_ALLOWED_USERS=

# filled automatically by `./install.sh register-dash`
HERMES_DASHBOARD_OAUTH_CLIENT_ID=
